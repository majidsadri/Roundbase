generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Investor {
  id        String   @id
  userId    String   @default("")
  name      String
  firm      String   @default("")
  role      String   @default("")
  email     String   @default("")
  linkedin  String   @default("")
  checkSize String   @default("")
  stage     String   @default("")
  sectors   String   @default("[]") // JSON array
  location  String   @default("")
  introPath String   @default("")
  notes     String   @default("")
  source    String   @default("")
  website   String   @default("")
  createdAt String

  pipelineEntries PipelineEntry[]

  @@index([userId])
}

model Project {
  id              String  @id
  userId          String  @default("")
  name            String
  description     String  @default("")
  stage           String  @default("")
  deckUrl         String  @default("")
  raiseAmount     String  @default("")
  targetInvestors String  @default("")
  sectors         String  @default("[]") // JSON array
  location        String  @default("")
  website         String  @default("")
  logoUrl         String  @default("") // URL or local path to project logo
  createdAt       String

  files           ProjectFile[]
  pipelineEntries PipelineEntry[]

  @@index([userId])
}

model ProjectFile {
  id         String @id @default(cuid())
  projectId  String
  name       String
  type       String // deck, pitch, onepager, financials, other
  filePath   String // relative path under /uploads
  uploadedAt String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PipelineEntry {
  id            String  @id
  userId        String  @default("")
  projectId     String
  investorId    String
  stage         String  // PipelineStage
  notes         String  @default("")
  lastContact   String  @default("")
  nextFollowup  String  @default("")
  meetingDate   String?
  meetingNotes  String?
  commitAmount  String  @default("")
  commitStatus  String  @default("") // interested, verbal, soft_circle, committed, wired
  feedback      String  @default("") // JSON array of meeting feedback
  createdAt     String

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  investor   Investor   @relation(fields: [investorId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@index([userId])
}

model PublicFirm {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String  @default("")
  logoUrl     String  @default("")
  website     String  @default("")
  linkedin    String  @default("")
  hq          String  @default("")
  stages      String  @default("[]")
  sectors     String  @default("[]")
  checkMin    String  @default("")
  checkMax    String  @default("")
  fundSize    String  @default("")
  portfolio   String  @default("[]")
  founded     String  @default("")
  teamSize    String  @default("")
  type        String  @default("vc")
  featured    Boolean @default(false)
  createdAt   String
  updatedAt   String

  @@index([slug])
  @@index([type])
}

model Activity {
  id         String  @id
  pipelineId String
  type       String // email, meeting, call, note, linkedin
  date       String
  notes      String  @default("")
  subject    String?

  pipelineEntry PipelineEntry @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}
